{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "outDir": "./dist",
    "removeComments": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "sourceMap": true,
    "strict": true,
    "target": "ES2016",
    "lib": ["ES2016", "DOM"],
    "types": ["node", "jest"]
  },
  "exclude": ["airdrops", "flow", "lockup", "node_modules", "periphery"],
  "include": ["src/**/*"]
}
